# ==========================================
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ==========================================
# 6. APP UPLOADS & LOCAL CONFIG (Ảnh test local, không up lên server)
# ==========================================
PBMS/wwwroot/uploads/*
!PBMS/wwwroot/uploads/.gitkeep
*.local.settings.json
appsettings.Development.json